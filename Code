FullScreenFrame.Parent = ScreenGui

local currentEffect = nil

Tab:CreateToggle({
    Name = "White Screen",
    Info = {
        Title = 'White Screen',
        Image = '12735851647',
        Description = 'SAVE MY CPU PLSSS',
    },
    CurrentValue = false,
    Flag = "ToggleWhiteScreen",
    Callback = function(Value)
        if Value then
            if currentEffect == "Black" then
                FullScreenFrame.Visible = false
            end
            FullScreenFrame.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
            FullScreenFrame.Visible = true
            currentEffect = "White"
        else
            if currentEffect == "White" then
                FullScreenFrame.Visible = false
                currentEffect = nil
            end
        end
    end,
})

Tab:CreateToggle({
    Name = "Black Screen",
    Info = {
        Title = 'Black Screen',
        Image = '12735851647',
        Description = 'Save My Cpu PLSSS',
    },
    CurrentValue = false,
    Flag = "ToggleBlackScreen",
    Callback = function(Value)
        if Value then
            if currentEffect == "White" then
                FullScreenFrame.Visible = false
            end
            FullScreenFrame.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
            FullScreenFrame.Visible = true
            currentEffect = "Black"
        else
            if currentEffect == "Black" then
                FullScreenFrame.Visible = false
                currentEffect = nil
            end
        end
    end,
})



