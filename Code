local function fetchPlayerStats()
    local player = game:GetService("Players").LocalPlayer
    local coins, coinsMultiplier, diamonds = "N/A", "N/A", "N/A"
    
    if showCoins then
        local coinsGui = player.PlayerGui.Main.Top.Coins.Amount
        if coinsGui then
            coins = coinsGui.Text
        end
    end
    
    if showCoinsMultiplier then
        local multGui = player.PlayerGui.Main.Top.Coins.Icon.Mult
        if multGui then
            coinsMultiplier = multGui.Text
        end
    end
    
    if showDiamonds then
        local diamondsGui = player.PlayerGui.Main.Top.Diamonds.Amount
        if diamondsGui then
            diamonds = diamondsGui.Text
        end
    end

    return coins, coinsMultiplier, diamonds
end
local function sendWebhookMessage()
    if not sendMessageToWebhook or WebhookURL == "" then return end
    
    local player = game:GetService("Players").LocalPlayer
    local coins, coinsMultiplier, diamonds = fetchPlayerStats()

    local embed = {
        ["title"] = "Rinns Hub Pets Go",
        ["description"] = "Today at " .. os.date("%I:%M %p"),
        ["color"] = 16711680,
        ["fields"] = {
            {
                ["name"] = "Coins",
                ["value"] = coins,
                ["inline"] = true
            },
            {
                ["name"] = "Coins Multiplier",
                ["value"] = coinsMultiplier,
                ["inline"] = true
            },
            {
                ["name"] = "Diamonds",
                ["value"] = diamonds,
                ["inline"] = true
            },
        },
        ["footer"] = {
            ["text"] = "Rinns Hub https://discord.gg/3jsa6zvs2X",
            ["icon_url"] = "https://cdn.discordapp.com/icons/1046775262303494155/8196a5e833dbe7b11bcf50071ed3da55.webp?size=96"
        }
    }

    local msg = {
        ["embeds"] = {embed},
        ["username"] = "Rinns Hub Data 🥱",
        ["avatar_url"] = "https://cdn.discordapp.com/icons/1046775262303494155/8196a5e833dbe7b11bcf50071ed3da55.webp?size=96",
    }

    local request = http_request or request or HttpPost or syn.request
    request({
        Url = WebhookURL,
        Method = "POST",
        Headers = {
            ["Content-Type"] = "application/json",
        },
        Body = game:GetService("HttpService"):JSONEncode(msg),
    })
end

local function startAutoSend()
    while true do
        if sendMessageToWebhook then
            sendWebhookMessage()
        end
        task.wait(sendFrequency)
    end
end

coroutine.wrap(startAutoSend)()

