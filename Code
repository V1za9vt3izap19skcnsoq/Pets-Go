local function getDistance(part1, part2)
    if part1 and part1:IsA("BasePart") and part2 and part2:IsA("BasePart") then
        return (part1.Position - part2.Position).Magnitude
    end
    return math.huge
end

local function findClosestPrimaryParts(model, allParts, count)
    local closestParts = {}
    if model.PrimaryPart then
        table.sort(allParts, function(a, b)
            return getDistance(model.PrimaryPart, a.PrimaryPart) < getDistance(model.PrimaryPart, b.PrimaryPart)
        end)
        for i = 1, math.min(count, #allParts) do
            if allParts[i].PrimaryPart then
                table.insert(closestParts, allParts[i].PrimaryPart)
            end
        end
    end
    return closestParts
end

local pets = {}
for _, pet in pairs(PetsFolder:GetChildren()) do
    if pet:IsA("Model") and pet.PrimaryPart then
        table.insert(pets, pet)
    end
end

local function hasTouchInterest(model)
    for _, descendant in pairs(model:GetDescendants()) do
        if descendant:IsA("TouchTransmitter") then
            return true
        end
    end
    return false
end

function startAutoFarm()
    spawn(function()
        while autoFarmEnabled do
            local breakables = BreakablesFolder:GetChildren()

            if #breakables > 0 then
                local randomBreakable = breakables[math.random(1, #breakables)]
                if randomBreakable and randomBreakable:IsA("Model") and randomBreakable.PrimaryPart and randomBreakable.PrimaryPart:IsA("BasePart") and not hasTouchInterest(randomBreakable) then
                    local closestPets = findClosestPrimaryParts(randomBreakable, pets, 4)
                    for _, pet in pairs(closestPets) do
                        local args = {
                            [1] = {
                                [pet.Name] = randomBreakable:GetAttribute("BreakableUID")
                            }
                        }
                        spawn(function()
                            RemoteEvent:FireServer(unpack(args))
                        end)
                    end
                end
            end

            wait(farmSpeed)
        end
    end)
end



