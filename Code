local function getScreenPosition(worldPosition)
    local screenPos, onScreen = camera:WorldToViewportPoint(worldPosition)
    if onScreen then
        return Vector2.new(screenPos.X, screenPos.Y), onScreen
    end
    return nil, false
end

local function hasTouchInterest(model)
    for _, descendant in pairs(model:GetDescendants()) do
        if descendant:IsA("TouchTransmitter") then
            return true
        end
    end
    return false
end

local function getClosestBreakable()
    local closestBreakable = nil
    local shortestDistance = math.huge

    for _, breakable in pairs(breakables:GetChildren()) do
        if breakable:IsA("Model") and breakable.PrimaryPart and not hasTouchInterest(breakable) then
            local distance = (player.Character.HumanoidRootPart.Position - breakable.PrimaryPart.Position).Magnitude
            if distance < shortestDistance then
                closestBreakable = breakable
                shortestDistance = distance
            end
        end
    end

    return closestBreakable
end

