local autoBuyEnabled = false
local completedChildren = {}

Tab:CreateToggle({
    Name = "Auto Buy Upgrades",
    Info = {
        Title = 'Slider template',
        Image = '12735851647',
        Description = 'Just a slider for stuff',
    },
    CurrentValue = false,
    Flag = "Toggle1",
    Callback = function(Value)
        autoBuyEnabled = Value
        if autoBuyEnabled then
            spawn(function()
                while autoBuyEnabled do
                    local upgrades = game:GetService("ReplicatedStorage").__DIRECTORY.Upgrades:GetDescendants()
                    for _, descendant in ipairs(upgrades) do
                        if not table.find(completedChildren, descendant.Name) then
                            local args = {
                                [1] = descendant.Name
                            }
                            game:GetService("ReplicatedStorage").Network.Upgrades_Purchase:InvokeServer(unpack(args))
                            table.insert(completedChildren, descendant.Name)
                            task.wait(0.85)
                        end
                        if not autoBuyEnabled then
                            break
                        end
                    end
                    if #completedChildren == #upgrades then
                        completedChildren = {}
                    end
                    if not autoBuyEnabled then
                        break
                    end
                end
            end)
        else
            completedChildren = {}
        end
    end,
})

