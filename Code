local function teleportToBreakable(breakable)
    if player.Character and player.Character:FindFirstChild("HumanoidRootPart") and breakable and breakable.PrimaryPart then
        local breakablePosition = breakable.PrimaryPart.Position
        local offset = Vector3.new(-5, 0, 0)
        player.Character.HumanoidRootPart.CFrame = CFrame.new(breakablePosition + offset)
    end
end

