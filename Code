    },
    CurrentValue = false,
    Flag = "Toggle1",
    Callback = function(Value)
        relicEspEnabled = Value
        if not relicEspEnabled then
            for _, line in pairs(RelicLines) do
                line.Visible = false
                line:Remove()
            end
            RelicLines = {}
        end
    end,
})

local function createLineToRelic(relic)
    if relic.Transparency == 0.75 then return end
    local line = Drawing.new("Line")
    line.Thickness = 2
    line.Color = Color3.new(1, 0, 0)
    line.Transparency = 1
    line.Visible = true
    RelicLines[relic] = line
end

runService.RenderStepped:Connect(function()
    if relicEspEnabled and head then
        for _, relic in ipairs(relicsFolder:GetChildren()) do
            if relic:IsA("MeshPart") and relic.Name == "Relic" then
                if relic.Transparency == 0.75 then
                    if RelicLines[relic] then
                        RelicLines[relic]:Remove()
                        RelicLines[relic] = nil
                    end
                else
                    if not RelicLines[relic] then
                        createLineToRelic(relic)
                    end
                    local headPos, onScreenHead = camera:WorldToViewportPoint(head.Position)
                    local relicPos, onScreenRelic = camera:WorldToViewportPoint(relic.Position)
                    if onScreenHead and onScreenRelic then
                        RelicLines[relic].From = Vector2.new(headPos.X, headPos.Y)
                        RelicLines[relic].To = Vector2.new(relicPos.X, relicPos.Y)
                        RelicLines[relic].Visible = true
                    else
                        RelicLines[relic].Visible = false
                    end
                end
            end
        end
    end
end)

local function getScreenPosition(worldPosition)
    local screenPos, onScreen = camera:WorldToViewportPoint(worldPosition)
    if onScreen then
        return Vector2.new(screenPos.X, screenPos.Y), onScreen
    end
    return nil, false
end

local function simulateMouseClicks(relic)
    local screenPosition, isOnScreen = getScreenPosition(relic.Position)
    if isOnScreen and screenPosition then
        while relic and relic.Parent and relic.Transparency ~= 0.75 and getAllRelicsEnabled do
            VirtualInputManager:SendMouseButtonEvent(screenPosition.X, screenPosition.Y, 0, true, game, 0)
            task.wait(0.01)
            VirtualInputManager:SendMouseButtonEvent(screenPosition.X, screenPosition.Y, 0, false, game, 0)
            task.wait(0.01)
            screenPosition, isOnScreen = getScreenPosition(relic.Position)
        end
    end
end

local function collectRelics()
    while getAllRelicsEnabled do
        local nextRelic = nil
        for _, relic in ipairs(relicsFolder:GetChildren()) do
            if relic:IsA("MeshPart") and relic.Name == "Relic" and relic.Transparency ~= 0.75 then
                nextRelic = relic
                break
            end
        end

        if nextRelic and character then
            player.Character:SetPrimaryPartCFrame(nextRelic.CFrame)
            simulateMouseClicks(nextRelic)
        else
            break
        end
        task.wait(0.1)
    end
end

